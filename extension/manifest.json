{
  "manifest_version": 3,
  "name": "InfoFlow Clipper",
  "version": "0.1.0",
  "description": "Save any web content to InfoFlow",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
